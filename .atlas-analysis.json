  "publicApiSurface": [
    "BasicApi::initGet() - Initialize manager connection",
    "BasicApi::pingGet() - Ping API connection",
    "AccountApi::accountLoginGet() - Get account by login",
    "UserApi::userAddPost() - Create new user",
    "UserApi::updateUser() - Update existing user",
    "UserApi::userUserLoginGet() - Get user by login",
    "UserApi::userUserLoginDelete() - Delete user",
    "UserApi::usersGroupGet() - Get users by group",
    "UserApi::userDepositPost() - Deposit to account",
    "UserApi::userWithdrawPost() - Withdraw from account",
    "UserApi::userResetPwdPost() - Reset user password",
    "TradeApi::positionsUserLoginGet() - Get user positions",
    "TradeApi::ordersUserLoginGet() - Get user orders",
    "TradeApi::dealsUserLoginGet() - Get user deals",
    "TradeApi::closeAllUserLoginDelete() - Close all positions",
    "GroupApi::groupsGet() - Get all groups",
    "GroupApi::groupGroupNameGet() - Get group by name",
    "SymbolApi::symbolsGet() - Get market symbols",
    "Account model - Account data structure",
    "User model - User data structure",
    "Position model - Position data structure",
    "Order model - Order data structure",
    "Deal model - Deal data structure",
    "Group model - Group data structure",
    "Symbol model - Symbol data structure"
